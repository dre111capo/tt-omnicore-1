# Makefile for OmniCore-1 Verilator hardware emulation
# Usage: make -f test/Makefile.verilator all

VERILATOR = verilator
CXX = g++
CXXFLAGS = -O3 -Wall -Iobj_dir -I/usr/local/share/verilator/include -I/usr/share/verilator/include

SRC_DIR = src
TEST_DIR = test
OBJ_DIR = obj_dir
BIN_DIR = bin

TARGET = $(BIN_DIR)/omnicore_pc_sim
RTL_SRC = $(SRC_DIR)/tt_um_omnicore.v
SIM_SRC = $(TEST_DIR)/sim_main.cpp

.PHONY: all run clean

all: $(TARGET)

$(TARGET): $(RTL_SRC) $(SIM_SRC)
	@mkdir -p $(BIN_DIR)
	@mkdir -p $(OBJ_DIR)
	@echo "[VERILATOR] Compiling Verilog and C++ sources..."
	$(VERILATOR) --cc --exe --build -O3 -Wall \
		-Wno-fatal \
		-I$(SRC_DIR) \
		-Mdir $(OBJ_DIR) \
		$(RTL_SRC) $(SIM_SRC) \
		-o ../$(TARGET)
	@echo "[SUCCESS] Built executable at $(TARGET)"

run: all
	@echo "[RUN] Executing Virtual Motherboard..."
	@./$(TARGET)

clean:
	rm -rf $(OBJ_DIR) $(BIN_DIR)
